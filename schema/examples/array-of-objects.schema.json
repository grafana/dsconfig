{
    "schemaVersion": "v1",
    "pluginType": "example-array",
    "pluginName": "Array of Objects Datasource",
    "fields": [
        {
            "id": "connection.url",
            "key": "url",
            "valueType": "string",
            "semanticType": "url",
            "target": "root",
            "required": true,
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.tracesToMetrics",
            "key": "tracesToMetrics",
            "label": "Trace to Metrics Queries",
            "description": "Link traces to metrics queries",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "object",
                "fields": [
                    {
                        "id": "tracesToMetrics.item.name",
                        "key": "name",
                        "label": "Query Name",
                        "valueType": "string",
                        "isItemField": true,
                        "required": true
                    },
                    {
                        "id": "tracesToMetrics.item.query",
                        "key": "query",
                        "label": "PromQL Query",
                        "valueType": "string",
                        "isItemField": true,
                        "ui": {
                            "component": "textarea",
                            "rows": 3
                        }
                    }
                ]
            },
            "validations": [
                {
                    "type": "itemCount",
                    "max": 20,
                    "message": "Maximum 20 trace-to-metric queries"
                }
            ]
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "fieldRefs": [
                "connection.url"
            ]
        },
        {
            "id": "trace-metrics",
            "title": "Trace to Metrics",
            "fieldRefs": [
                "jsonData.tracesToMetrics"
            ]
        }
    ]
}
