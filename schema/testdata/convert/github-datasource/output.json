{
    "spec": {
        "type": "object",
        "properties": {
            "url": {
                "description": "GitHub API URL (only needed for Enterprise Server)",
                "type": "string",
                "format": "uri"
            },
            "jsonData": {
                "type": "object",
                "properties": {
                    "githubPlan": {
                        "description": "GitHub plan type",
                        "type": "string",
                        "default": "github-basic",
                        "enum": [
                            "github-basic",
                            "github-enterprise-cloud",
                            "github-enterprise-server"
                        ]
                    },
                    "githubUrl": {
                        "description": "The URL of the GitHub Enterprise Server instance",
                        "type": "string",
                        "format": "uri",
                        "x-depends-on": "jsonData.githubPlan == 'github-enterprise-server'",
                        "x-required-when": "jsonData.githubPlan == 'github-enterprise-server'",
                        "x-disabled-when": "jsonData.githubPlan != 'github-enterprise-server'"
                    },
                    "selectedAuthType": {
                        "description": "Authentication type",
                        "type": "string",
                        "default": "personal-access-token",
                        "enum": [
                            "personal-access-token",
                            "github-app"
                        ]
                    },
                    "appId": {
                        "description": "The GitHub App ID",
                        "type": "string",
                        "x-depends-on": "jsonData.selectedAuthType == 'github-app'",
                        "x-required-when": "jsonData.selectedAuthType == 'github-app'",
                        "x-disabled-when": "jsonData.selectedAuthType != 'github-app'"
                    },
                    "installationId": {
                        "description": "The GitHub App installation ID",
                        "type": "string",
                        "x-depends-on": "jsonData.selectedAuthType == 'github-app'",
                        "x-required-when": "jsonData.selectedAuthType == 'github-app'",
                        "x-disabled-when": "jsonData.selectedAuthType != 'github-app'"
                    }
                }
            }
        }
    },
    "secureValues": [
        {
            "key": "accessToken",
            "description": "Personal access token for GitHub API authentication",
            "x-depends-on": "jsonData.selectedAuthType == 'personal-access-token'",
            "x-required-when": "jsonData.selectedAuthType == 'personal-access-token'"
        },
        {
            "key": "privateKey",
            "description": "Private key for GitHub App authentication (PEM format)",
            "x-depends-on": "jsonData.selectedAuthType == 'github-app'",
            "x-required-when": "jsonData.selectedAuthType == 'github-app'"        }
    ]
}