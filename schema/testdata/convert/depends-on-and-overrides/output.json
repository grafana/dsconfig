{
    "spec": {
        "type": "object",
        "required": [
            "url"
        ],
        "properties": {
            "url": {
                "description": "Server URL",
                "type": "string",
                "format": "uri"
            },
            "jsonData": {
                "type": "object",
                "properties": {
                    "authType": {
                        "description": "Authentication type",
                        "type": "string",
                        "default": "none",
                        "enum": [
                            "none",
                            "basic",
                            "oauth"
                        ]
                    },
                    "username": {
                        "description": "Username for authentication",
                        "type": "string",
                        "x-dsconfig-depends-on": "auth.type == 'basic'",
                        "x-dsconfig-required-when": "auth.type == 'basic'"
                    },
                    "tokenUrl": {
                        "description": "OAuth token endpoint URL",
                        "type": "string",
                        "format": "uri",
                        "x-dsconfig-depends-on": "auth.type == 'oauth'",
                        "x-dsconfig-required-when": "auth.type == 'oauth'"
                    }
                }
            }
        }
    },
    "secureValues": [
        {
            "key": "password",
            "description": "Password for authentication",
            "x-dsconfig-depends-on": "auth.type != 'none'",
            "x-dsconfig-required-when": "auth.type == 'basic'"
        }
    ]
}
