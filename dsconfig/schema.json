{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/grafana/ds/blob/main/dsconfig/schema.json",
    "title": "Datasource Configuration Schema",
    "description": "Declarative schema for Grafana datasource configuration including UI, validation, behavior, relationships, and storage mapping.",
    "type": "object",
    "required": [
        "$schema",
        "schemaVersion",
        "pluginType",
        "pluginName",
        "fields"
    ],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "const": "https://raw.githubusercontent.com/grafana/dsconfig/refs/heads/main/dsconfig/schema.json"
        },
        "schemaVersion": {
            "type": "string",
            "description": "Version of this schema specification",
            "enum": [
                "v1"
            ]
        },
        "pluginType": {
            "type": "string",
            "description": "Unique identifier of the datasource plugin"
        },
        "pluginName": {
            "type": "string",
            "description": "Human readable name"
        },
        "docURL": {
            "type": "string",
            "format": "uri"
        },
        "fields": {
            "type": "array",
            "description": "Source of truth for all config fields",
            "items": {
                "$ref": "#/definitions/ConfigField"
            }
        },
        "groups": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/ConfigGroup"
            }
        },
        "relationships": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/FieldRelationship"
            }
        },
        "instructions": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "msg"
                ],
                "properties": {
                    "msg": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "ConfigField": {
            "type": "object",
            "title": "Config Field",
            "required": [
                "id",
                "key",
                "valueType"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Globally unique identifier. Recommended format: dot-separated path (e.g. 'auth.method', 'httpHeaders.item.key')"
                },
                "key": {
                    "type": "string",
                    "description": "Local key"
                },
                "label": {
                    "type": "string"
                },
                "description": {
                    "type": "string",
                    "description": "Short, one-line field summary in inline Markdown (emphasis, links, code spans). Shared by docs, provisioning, and LLM consumers; editors also surface it as the field's tooltip. For rich, multi-step help use 'help' instead."
                },
                "docURL": {
                    "type": "string",
                    "format": "uri"
                },
                "help": {
                    "$ref": "#/definitions/FieldHelp"
                },
                "valueType": {
                    "type": "string",
                    "enum": [
                        "string",
                        "number",
                        "boolean",
                        "array",
                        "object",
                        "map",
                        "any"
                    ]
                },
                "target": {
                    "type": "string",
                    "enum": [
                        "root",
                        "jsonData",
                        "secureJsonData"
                    ],
                    "description": "Storage location. Required for storage fields."
                },
                "section": {
                    "type": "string",
                    "description": "Dotted path prefix within the target for nested objects. Example: for jsonData.tracesToLogs.datasourceUid, target=jsonData, section=tracesToLogs, key=datasourceUid."
                },
                "kind": {
                    "type": "string",
                    "enum": [
                        "storage",
                        "virtual"
                    ],
                    "default": "storage"
                },
                "role": {
                    "type": "string",
                    "description": "Optional semantic tag from a closed, versioned vocabulary describing what the field means, independent of its key, so generic consumers can find it across plugins. Optional and incremental; unknown values are rejected at validation.",
                    "enum": [
                        "endpoint.baseUrl",
                        "endpoint.scheme",
                        "endpoint.domain",
                        "endpoint.port",
                        "transport.timeoutSeconds",
                        "transport.tlsSkipVerify",
                        "tls.clientCert",
                        "tls.clientKey",
                        "tls.caCert",
                        "tls.serverName",
                        "auth.discriminator",
                        "auth.basic.enabled",
                        "auth.basic.username",
                        "auth.basic.password",
                        "auth.basic.token",
                        "auth.bearer.token",
                        "auth.oauth2.clientId",
                        "auth.oauth2.clientSecret",
                        "auth.oauth2.tokenUrl",
                        "auth.oauth2.jwtPrivateKey",
                        "auth.jwt.signingKey",
                        "auth.awsSigV4.enabled",
                        "auth.aws.accessKeyId",
                        "auth.aws.secretAccessKey",
                        "auth.azureBlob.storageAccountKey",
                        "auth.forwardOAuthToken.enabled",
                        "auth.apiKey.key",
                        "auth.apiKey.value",
                        "http.header",
                        "http.header.name",
                        "http.header.value",
                        "http.query",
                        "http.query.name",
                        "http.query.value"
                    ]
                },
                "isItemField": {
                    "type": "boolean",
                    "description": "Must be true for fields inside array item schemas"
                },
                "ui": {
                    "$ref": "#/definitions/FieldUI"
                },
                "validations": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FieldValidationRule"
                    }
                },
                "dependsOn": {
                    "type": "string"
                },
                "required": {
                    "type": "boolean"
                },
                "requiredWhen": {
                    "type": "string"
                },
                "disabledWhen": {
                    "type": "string"
                },
                "overrides": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FieldOverride"
                    }
                },
                "effects": {
                    "type": "array",
                    "description": "Declarative multi-field write side-effects. When this field's value matches a condition, the listed target fields are set to specified values.",
                    "items": {
                        "$ref": "#/definitions/FieldEffect"
                    }
                },
                "item": {
                    "$ref": "#/definitions/FieldItemSchema"
                },
                "repeatable": {
                    "type": "boolean",
                    "description": "Legacy indexed fields. Prefer indexedPair mapping.",
                    "default": false
                },
                "pattern": {
                    "type": "string",
                    "description": "Pattern for repeatable fields (legacy)"
                },
                "storage": {
                    "$ref": "#/definitions/StorageMapping"
                },
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "examples": {
                    "type": "array",
                    "items": {}
                },
                "defaultValue": {}
            },
            "allOf": [
                {
                    "if": {
                        "not": {
                            "anyOf": [
                                {
                                    "properties": {
                                        "kind": {
                                            "const": "virtual"
                                        }
                                    },
                                    "required": [
                                        "kind"
                                    ]
                                },
                                {
                                    "properties": {
                                        "isItemField": {
                                            "const": true
                                        }
                                    },
                                    "required": [
                                        "isItemField"
                                    ]
                                }
                            ]
                        }
                    },
                    "then": {
                        "required": [
                            "target"
                        ]
                    }
                },
                {
                    "if": {
                        "type": "object",
                        "properties": {
                            "valueType": {
                                "enum": [
                                    "array",
                                    "map"
                                ]
                            }
                        },
                        "required": [
                            "valueType"
                        ]
                    },
                    "then": {
                        "required": [
                            "item"
                        ]
                    }
                }
            ]
        },
        "FieldItemSchema": {
            "type": "object",
            "required": [
                "valueType"
            ],
            "additionalProperties": false,
            "properties": {
                "valueType": {
                    "type": "string",
                    "enum": [
                        "string",
                        "number",
                        "boolean",
                        "array",
                        "object",
                        "map",
                        "any"
                    ]
                },
                "fields": {
                    "type": "array",
                    "items": {
                        "allOf": [
                            {
                                "$ref": "#/definitions/ConfigField"
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "isItemField": {
                                        "const": true
                                    }
                                },
                                "required": [
                                    "isItemField"
                                ]
                            }
                        ]
                    }
                }
            }
        },
        "StorageMapping": {
            "oneOf": [
                {
                    "$ref": "#/definitions/DirectMapping"
                },
                {
                    "$ref": "#/definitions/IndexedPairMapping"
                },
                {
                    "$ref": "#/definitions/ComputedMapping"
                }
            ]
        },
        "DirectMapping": {
            "type": "object",
            "required": [
                "type"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "const": "direct"
                }
            }
        },
        "IndexedPairMapping": {
            "type": "object",
            "required": [
                "type",
                "key",
                "value"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "const": "indexedPair"
                },
                "key": {
                    "$ref": "#/definitions/MappingField"
                },
                "value": {
                    "$ref": "#/definitions/MappingField"
                },
                "startIndex": {
                    "type": "number"
                }
            }
        },
        "ComputedMapping": {
            "type": "object",
            "required": [
                "type"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "const": "computed"
                },
                "read": {
                    "type": "string"
                },
                "write": {
                    "type": "string"
                }
            },
            "anyOf": [
                {
                    "required": [
                        "read"
                    ]
                },
                {
                    "required": [
                        "write"
                    ]
                }
            ]
        },
        "MappingField": {
            "type": "object",
            "required": [
                "target",
                "pattern"
            ],
            "additionalProperties": false,
            "properties": {
                "target": {
                    "type": "string",
                    "enum": [
                        "root",
                        "jsonData",
                        "secureJsonData"
                    ]
                },
                "pattern": {
                    "type": "string"
                }
            }
        },
        "FieldUI": {
            "type": "object",
            "required": [
                "component"
            ],
            "additionalProperties": false,
            "properties": {
                "component": {
                    "type": "string",
                    "enum": [
                        "input",
                        "textarea",
                        "select",
                        "multiselect",
                        "radio",
                        "checkbox",
                        "switch",
                        "code",
                        "keyvalue",
                        "list",
                        "fileUpload"
                    ]
                },
                "multiline": {
                    "type": "boolean"
                },
                "rows": {
                    "type": "number"
                },
                "options": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FieldOption"
                    }
                },
                "allowCustom": {
                    "type": "boolean"
                },
                "width": {
                    "type": "string",
                    "enum": [
                        "full",
                        "half"
                    ]
                },
                "placeholder": {
                    "type": "string"
                },
                "language": {
                    "type": "string",
                    "description": "Language hint for code editor components. Example: promql, logql, traceql, sql, json."
                },
                "accept": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "File types allowed by a fileUpload component, using the same syntax as the HTML input 'accept' attribute: file extensions (.json, .pem) and/or MIME types (application/json)."
                },
                "fileMapping": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Maps keys from an uploaded file (e.g. a GCP service account JSON) to destination config paths for a fileUpload component. Keys are fields within the file; values are dotted paths rooted at 'jsonData' or 'secureJsonData'. Example: {\"project_id\": \"jsonData.defaultProject\", \"private_key\": \"secureJsonData.privateKey\"}."
                }
            }
        },
        "FieldHelp": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "markdown"
            ],
            "description": "Optional rich, custom help for a field, rendered as a drawer/side panel for content too involved for a tooltip (multi-step instructions, links, code). For short help, use the field's 'description', which editors surface as a tooltip; do not duplicate it here.",
            "properties": {
                "title": {
                    "type": "string",
                    "description": "Drawer heading; also used as the trigger label that opens the drawer."
                },
                "subtitle": {
                    "type": "string",
                    "description": "Optional secondary drawer heading."
                },
                "markdown": {
                    "type": "string",
                    "description": "Help body in block Markdown: multi-step instructions, links, and code blocks. For short, one-line help use the field's 'description' instead."
                },
                "docURL": {
                    "type": "string",
                    "format": "uri",
                    "description": "Optional documentation link surfaced in the drawer."
                }
            }
        },
        "FieldValidationRule": {
            "type": "object",
            "title": "Field Validation Rule",
            "description": "A single validation rule. Uses 'type' as discriminator.",
            "required": [
                "type"
            ],
            "additionalProperties": true,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Optional stable ID for docs, localization, and test snapshots."
                },
                "message": {
                    "type": "string",
                    "description": "Human-readable validation error message."
                },
                "type": {
                    "enum": [
                        "pattern",
                        "range",
                        "length",
                        "itemCount",
                        "allowedValues",
                        "custom"
                    ]
                }
            },
            "oneOf": [
                {
                    "properties": {
                        "type": {
                            "const": "pattern"
                        },
                        "pattern": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "type",
                        "pattern"
                    ]
                },
                {
                    "properties": {
                        "type": {
                            "const": "range"
                        },
                        "min": {
                            "type": "number"
                        },
                        "max": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "type"
                    ],
                    "anyOf": [
                        {
                            "required": [
                                "min"
                            ]
                        },
                        {
                            "required": [
                                "max"
                            ]
                        }
                    ]
                },
                {
                    "properties": {
                        "type": {
                            "const": "length"
                        },
                        "min": {
                            "type": "number"
                        },
                        "max": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "type"
                    ],
                    "anyOf": [
                        {
                            "required": [
                                "min"
                            ]
                        },
                        {
                            "required": [
                                "max"
                            ]
                        }
                    ]
                },
                {
                    "properties": {
                        "type": {
                            "const": "itemCount"
                        },
                        "min": {
                            "type": "number"
                        },
                        "max": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "type"
                    ],
                    "anyOf": [
                        {
                            "required": [
                                "min"
                            ]
                        },
                        {
                            "required": [
                                "max"
                            ]
                        }
                    ]
                },
                {
                    "properties": {
                        "type": {
                            "const": "allowedValues"
                        },
                        "values": {
                            "type": "array",
                            "items": {}
                        }
                    },
                    "required": [
                        "type",
                        "values"
                    ]
                },
                {
                    "properties": {
                        "type": {
                            "const": "custom"
                        },
                        "expression": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "type",
                        "expression"
                    ]
                }
            ]
        },
        "FieldOverride": {
            "type": "object",
            "required": [
                "when"
            ],
            "additionalProperties": false,
            "properties": {
                "when": {
                    "type": "string"
                },
                "defaultValue": {},
                "readOnly": {
                    "type": "boolean",
                    "description": "When true, the field is disabled/read-only while this override is active."
                },
                "description": {
                    "type": "string"
                },
                "placeholder": {
                    "type": "string"
                },
                "tooltip": {
                    "type": "string"
                },
                "validations": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FieldValidationRule"
                    }
                },
                "options": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FieldOption"
                    }
                }
            }
        },
        "FieldEffect": {
            "type": "object",
            "description": "Declares that when a field's value matches a condition, listed target fields should be set to specified values.",
            "required": [
                "when",
                "set"
            ],
            "additionalProperties": false,
            "properties": {
                "when": {
                    "type": "string",
                    "description": "CEL expression. Use 'value' to refer to the field's current value. Example: \"value == 'basic-auth'\""
                },
                "set": {
                    "type": "object",
                    "description": "Maps field IDs to the values they should be set to when the condition matches.",
                    "minProperties": 1,
                    "additionalProperties": true
                }
            }
        },
        "FieldOption": {
            "type": "object",
            "required": [
                "label",
                "value"
            ],
            "additionalProperties": false,
            "properties": {
                "label": {
                    "type": "string"
                },
                "value": {
                    "not": {
                        "type": "null"
                    },
                    "description": "Option value. Must not be null. Must match parent field valueType."
                },
                "description": {
                    "type": "string"
                }
            }
        },
        "GroupUI": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "icon": {
                    "type": "string",
                    "description": "Optional Grafana icon name (a Grafana IconName such as 'plug', 'lock', or 'shield') that a Grafana editor may render next to the group in a settings sidebar. This is a Grafana-specific presentation hint only; non-Grafana consumers should ignore it, so it is always safe to omit or leave unhandled."
                }
            }
        },
        "ConfigGroup": {
            "type": "object",
            "required": [
                "id",
                "title",
                "fieldRefs"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "ui": {
                    "$ref": "#/definitions/GroupUI"
                },
                "order": {
                    "type": "number"
                },
                "optional": {
                    "type": "boolean"
                },
                "fieldRefs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "FieldRelationship": {
            "type": "object",
            "required": [
                "type",
                "fields"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "pair",
                        "group",
                        "datasourceReference"
                    ]
                },
                "fields": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "description": {
                    "type": "string"
                },
                "targetPluginType": {
                    "type": "string",
                    "description": "Constrains the datasource UID to a specific plugin type. Only applicable when type is datasourceReference."
                }
            }
        }
    }
}
