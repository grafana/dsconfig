{
  "targetApiVersion": "v0alpha1",
  "settings": {
    "spec": {
      "type": "object",
      "properties": {
        "jsonData": {
          "type": "object",
          "required": [
            "host",
            "port"
          ],
          "properties": {
            "aliasTables": {
              "description": "Provide alias tables with a (`alias` String, `select` String, `type` String) schema to use as a source for column selection.",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "aliasDatabase": {
                    "type": "string"
                  },
                  "aliasTable": {
                    "type": "string"
                  },
                  "targetDatabase": {
                    "type": "string"
                  },
                  "targetTable": {
                    "type": "string"
                  }
                }
              }
            },
            "configMode": {
              "description": "Choose how this datasource is used. 'Single table' provides a focused, compact query editor for one table. 'All databases' gives full access to explore any database and table.",
              "type": "string",
              "default": "classic",
              "enum": [
                "classic",
                "single-table"
              ]
            },
            "connMaxLifetime": {
              "description": "Maximum lifetime of a connection in minutes",
              "type": "string",
              "default": "5"
            },
            "customSettings": {
              "description": "Additional ClickHouse settings sent with every query as SETTINGS name=value.",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "setting": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                }
              }
            },
            "defaultDatabase": {
              "description": "the default database used by the query builder",
              "type": "string"
            },
            "defaultTable": {
              "description": "the default table used by the query builder",
              "type": "string"
            },
            "dialTimeout": {
              "description": "Timeout in seconds for connection",
              "type": "string",
              "default": "10"
            },
            "enableMapKeysDiscovery": {
              "description": "When enabled, the filter editor probes Map(...) columns for distinct keys to populate the key-suggestion dropdown. On large tables with high-cardinality maps this probe can scan billions of rows. Disable to suppress the probe — operators can still type Map keys manually. Defaults to enabled.",
              "type": "boolean",
              "default": true
            },
            "enableRowLimit": {
              "description": "Enable using the Grafana row limit setting to limit the number of rows returned from Clickhouse. Ensure the appropriate permissions are set for your user. Only supported for Grafana \u003e= 11.0.0. Defaults to false.",
              "type": "boolean",
              "default": false
            },
            "enableSchemaCache": {
              "description": "Gates the in-process cache that memoizes system.tables / system.columns / DISTINCT column-value lookups used by the query builder. Not exposed in the configuration editor; backend defaults it to true when unset.",
              "type": "boolean",
              "default": true
            },
            "forwardGrafanaHeaders": {
              "description": "Forward Grafana HTTP Headers to datasource.",
              "type": "boolean",
              "default": false,
              "x-dsconfig-depends-on": "jsonData_protocol == 'http'"
            },
            "hideTableNameInAdhocFilters": {
              "description": "Show only column names in ad hoc filter keys instead of the full \"table.column\" format. This simplifies the filter interface when working with schemas that have many tables. Defaults to false.",
              "type": "boolean",
              "default": false
            },
            "host": {
              "description": "Enter server address",
              "type": "string"
            },
            "httpHeaders": {
              "description": "Add Custom HTTP headers when querying the database",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "secure": {
                    "type": "boolean"
                  },
                  "value": {
                    "description": "Empty when the header is stored securely; the encrypted value lives in secureJsonData under secureHttpHeaders.\u003cHeader Name\u003e.",
                    "type": "string"
                  }
                }
              },
              "x-dsconfig-depends-on": "jsonData_protocol == 'http'"
            },
            "logs": {
              "type": "object",
              "properties": {
                "contextColumns": {
                  "description": "Comma separated list of column names to use for identifying a log's source",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "defaultDatabase": {
                  "description": "the default database used by the logs query builder",
                  "type": "string"
                },
                "defaultTable": {
                  "description": "the default table used by the logs query builder",
                  "type": "string",
                  "default": "otel_logs"
                },
                "filterTimeColumn": {
                  "description": "A lower precision column for filtering logs by timestamp",
                  "type": "string"
                },
                "levelColumn": {
                  "description": "Column for the log level",
                  "type": "string"
                },
                "messageColumn": {
                  "description": "Column for log message",
                  "type": "string"
                },
                "otelEnabled": {
                  "description": "Enables Open Telemetry schema versioning",
                  "type": "boolean"
                },
                "otelVersion": {
                  "type": "string",
                  "default": "latest"
                },
                "selectContextColumns": {
                  "description": "When enabled, will always include context columns in log queries",
                  "type": "boolean",
                  "default": true
                },
                "showLogLinks": {
                  "description": "Show \"View logs\" links on trace_id/traceid fields.",
                  "type": "boolean"
                },
                "timeColumn": {
                  "description": "Column for the log timestamp, used for high precision sorting",
                  "type": "string"
                }
              }
            },
            "maxIdleConns": {
              "description": "Maximum number of idle connections",
              "type": "string",
              "default": "25"
            },
            "maxOpenConns": {
              "description": "Maximum number of open connections",
              "type": "string",
              "default": "50"
            },
            "path": {
              "description": "Additional URL path for HTTP requests",
              "type": "string",
              "x-dsconfig-depends-on": "jsonData_protocol == 'http'"
            },
            "port": {
              "description": "ClickHouse server port",
              "type": "number",
              "default": 9000
            },
            "protocol": {
              "description": "Native or HTTP for server protocol",
              "type": "string",
              "default": "native",
              "enum": [
                "native",
                "http"
              ]
            },
            "queryTimeout": {
              "description": "Timeout in seconds for read queries",
              "type": "string",
              "default": "60"
            },
            "rowLimit": {
              "description": "Row Limit",
              "type": "number"
            },
            "schemaCacheTTLSeconds": {
              "description": "Controls how long schema-introspection results are considered fresh. Not exposed in the configuration editor; backend defaults it to 60 when unset or \u003c=0.",
              "type": "number",
              "default": 60
            },
            "secure": {
              "description": "Toggle on if the connection is secure",
              "type": "boolean",
              "default": false
            },
            "signalType": {
              "description": "What kind of data does this table contain?",
              "type": "string",
              "default": "logs",
              "enum": [
                "logs",
                "traces"
              ],
              "x-dsconfig-depends-on": "jsonData_configMode == 'single-table'"
            },
            "tlsAuth": {
              "description": "TLS Client Auth",
              "type": "boolean",
              "default": false
            },
            "tlsAuthWithCACert": {
              "description": "Needed for verifying self-signed TLS Certs",
              "type": "boolean",
              "default": false
            },
            "tlsSkipVerify": {
              "description": "Skip TLS Verify",
              "type": "boolean",
              "default": false
            },
            "traces": {
              "type": "object",
              "properties": {
                "defaultDatabase": {
                  "description": "the default database used by the trace query builder",
                  "type": "string"
                },
                "defaultTable": {
                  "description": "the default table used by the trace query builder",
                  "type": "string",
                  "default": "otel_traces"
                },
                "durationColumn": {
                  "description": "Column for the duration time",
                  "type": "string"
                },
                "durationUnit": {
                  "description": "Unit used by your Duration column. OTel stores nanoseconds; other schemas often use milliseconds or seconds.",
                  "type": "string",
                  "default": "nanoseconds",
                  "enum": [
                    "nanoseconds",
                    "microseconds",
                    "milliseconds",
                    "seconds"
                  ]
                },
                "flattenNested": {
                  "description": "Enable if your traces table was created with flatten_nested=1",
                  "type": "boolean",
                  "default": false
                },
                "instrumentationLibraryNameColumn": {
                  "description": "Column for the instrumentation library name",
                  "type": "string"
                },
                "instrumentationLibraryVersionColumn": {
                  "description": "Column for the instrumentation library version",
                  "type": "string"
                },
                "kindColumn": {
                  "description": "Column for the trace kind",
                  "type": "string"
                },
                "operationNameColumn": {
                  "description": "Column for the operation name",
                  "type": "string"
                },
                "otelEnabled": {
                  "description": "Enables Open Telemetry schema versioning",
                  "type": "boolean"
                },
                "otelVersion": {
                  "type": "string",
                  "default": "latest"
                },
                "parentSpanIdColumn": {
                  "description": "Column for the parent span ID",
                  "type": "string"
                },
                "serviceNameColumn": {
                  "description": "Column for the service name",
                  "type": "string"
                },
                "serviceTagsColumn": {
                  "description": "Column for the service tags",
                  "type": "string"
                },
                "showTraceLinks": {
                  "description": "Show \"View trace\" links on trace_id/traceid fields.",
                  "type": "boolean"
                },
                "spanIdColumn": {
                  "description": "Column for the span ID",
                  "type": "string"
                },
                "startTimeColumn": {
                  "description": "Column for the start time",
                  "type": "string"
                },
                "stateColumn": {
                  "description": "Column for the trace state",
                  "type": "string"
                },
                "statusCodeColumn": {
                  "description": "Column for the trace status code",
                  "type": "string"
                },
                "statusMessageColumn": {
                  "description": "Column for the trace status message",
                  "type": "string"
                },
                "tagsColumn": {
                  "description": "Column for the trace tags",
                  "type": "string"
                },
                "traceEventsColumnPrefix": {
                  "description": "Prefix for the events column (Events.Timestamp, Events.Name, etc.)",
                  "type": "string"
                },
                "traceIdColumn": {
                  "description": "Column for the trace ID",
                  "type": "string"
                },
                "traceLinksColumnPrefix": {
                  "description": "Prefix for the trace references column (Links.TraceId, Links.TraceState, etc.)",
                  "type": "string"
                },
                "traceTimestampTableSuffix": {
                  "description": "Suffix appended to the traces table name to locate a companion index keyed by TraceId with Start/End columns. When such a table exists, trace ID lookups narrow the main query to a small time window instead of scanning the whole table. Leave blank to use the OTel default (_trace_id_ts).",
                  "type": "string"
                }
              }
            },
            "username": {
              "description": "We recommend configuring a read-only user.",
              "type": "string"
            },
            "validateSql": {
              "description": "Validate SQL in the editor.",
              "type": "boolean",
              "default": false
            },
            "version": {
              "description": "Plugin version that last wrote this configuration. Stamped by the config editor's useConfigDefaults hook on every save; frontend-only.",
              "type": "string"
            }
          }
        }
      }
    },
    "secureValues": [
      {
        "key": "password",
        "description": "ClickHouse password"
      },
      {
        "key": "tlsCACert"
      },
      {
        "key": "tlsClientCert"
      },
      {
        "key": "tlsClientKey"
      }
    ]
  },
  "settingsExamples": {
    "examples": {
      "": {
        "summary": "Default configuration",
        "description": "The defaults a new datasource starts with: native protocol, insecure, classic mode. The user must still supply host, port, username, and secureJsonData.password to get a working datasource.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "connMaxLifetime": "5",
            "dialTimeout": "10",
            "enableMapKeysDiscovery": true,
            "maxIdleConns": "25",
            "maxOpenConns": "50",
            "protocol": "native",
            "queryTimeout": "60",
            "secure": false
          },
          "secureJsonData": {
            "password": ""
          }
        }
      },
      "httpSecureWithHeaders": {
        "summary": "HTTPS with custom headers",
        "description": "HTTP protocol on 8443 with TLS. Adds one plaintext HTTP header and one secure HTTP header — secure header values are stored under secureJsonData['secureHttpHeaders.\u003cHeader Name\u003e'] and the value in jsonData.httpHeaders is left empty.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "enableMapKeysDiscovery": true,
            "forwardGrafanaHeaders": true,
            "host": "clickhouse.internal",
            "httpHeaders": [
              {
                "name": "X-ClickHouse-User",
                "secure": false,
                "value": "grafana"
              },
              {
                "name": "X-Api-Key",
                "secure": true,
                "value": ""
              }
            ],
            "path": "clickhouse",
            "port": 8443,
            "protocol": "http",
            "secure": true,
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme",
            "secureHttpHeaders.X-Api-Key": "abcd1234"
          }
        }
      },
      "legacyV3ServerField": {
        "summary": "Legacy: v3 `server` / `timeout` fields",
        "description": "Datasources created before ClickHouse plugin v4 stored the host under jsonData.server and the dial timeout under jsonData.timeout. The backend still maps them into settings.Host and settings.DialTimeout at load time (pkg/plugin/settings.go:86-92,159-168); the config editor migrates them on first render. New configurations should use host and dialTimeout.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "enableMapKeysDiscovery": true,
            "port": 9000,
            "protocol": "native",
            "server": "legacy-clickhouse.internal",
            "timeout": 10,
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme"
          }
        }
      },
      "nativeInsecure": {
        "summary": "Native TCP, insecure",
        "description": "Typical local development setup: ClickHouse native protocol on port 9000, plain TCP, username/password auth.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "enableMapKeysDiscovery": true,
            "host": "localhost",
            "port": 9000,
            "protocol": "native",
            "secure": false,
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme"
          }
        }
      },
      "nativeSecure": {
        "summary": "Native TCP, TLS",
        "description": "ClickHouse Cloud-style setup: native protocol on port 9440 with TLS.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "enableMapKeysDiscovery": true,
            "host": "my-cluster.clickhouse.cloud",
            "port": 9440,
            "protocol": "native",
            "secure": true,
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme"
          }
        }
      },
      "otelLogsSingleTable": {
        "summary": "Single-table logs with OTel schema",
        "description": "configMode='single-table' + signalType='logs' pins the datasource to one table. Enabling logs.otelEnabled and picking an otelVersion makes the plugin fill every column-role field from the OTel column map at runtime.",
        "value": {
          "jsonData": {
            "configMode": "single-table",
            "enableMapKeysDiscovery": true,
            "host": "clickhouse.internal",
            "logs": {
              "defaultDatabase": "otel",
              "defaultTable": "otel_logs",
              "otelEnabled": true,
              "otelVersion": "latest",
              "selectContextColumns": true,
              "showLogLinks": true
            },
            "port": 9440,
            "protocol": "native",
            "secure": true,
            "signalType": "logs",
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme"
          }
        }
      },
      "otelTracesSingleTable": {
        "summary": "Single-table traces with OTel schema",
        "description": "configMode='single-table' + signalType='traces'. The plugin defaults traces.defaultTable to otel_traces and, with traces.otelEnabled=true, drives every column-role and duration unit from the OTel column map.",
        "value": {
          "jsonData": {
            "configMode": "single-table",
            "enableMapKeysDiscovery": true,
            "host": "clickhouse.internal",
            "port": 9440,
            "protocol": "native",
            "secure": true,
            "signalType": "traces",
            "traces": {
              "defaultDatabase": "otel",
              "defaultTable": "otel_traces",
              "durationUnit": "nanoseconds",
              "otelEnabled": true,
              "otelVersion": "latest",
              "showTraceLinks": true,
              "traceTimestampTableSuffix": "_trace_id_ts"
            },
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme"
          }
        }
      },
      "tlsClientAuth": {
        "summary": "mTLS with a client certificate",
        "description": "Enables jsonData.tlsAuth so the driver supplies a client certificate + key to the server. Populate both secureJsonData.tlsClientCert and secureJsonData.tlsClientKey as full PEM blocks including BEGIN/END lines.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "enableMapKeysDiscovery": true,
            "host": "clickhouse.internal",
            "port": 9440,
            "protocol": "native",
            "secure": true,
            "tlsAuth": true,
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme",
            "tlsClientCert": "-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n",
            "tlsClientKey": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
          }
        }
      },
      "tlsWithCACert": {
        "summary": "TLS with a custom CA",
        "description": "Enables jsonData.tlsAuthWithCACert so the driver verifies the server's certificate against secureJsonData.tlsCACert. Independent of tlsAuth.",
        "value": {
          "jsonData": {
            "configMode": "classic",
            "enableMapKeysDiscovery": true,
            "host": "clickhouse.internal",
            "port": 9440,
            "protocol": "native",
            "secure": true,
            "tlsAuthWithCACert": true,
            "username": "default"
          },
          "secureJsonData": {
            "password": "changeme",
            "tlsCACert": "-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
          }
        }
      }
    }
  }
}
