{
    "$schema": "https://raw.githubusercontent.com/grafana/dsconfig/refs/tags/dsconfig/v0.0.12/dsconfig/schema.json",
    "schemaVersion": "v1",
    "pluginType": "grafana-clickhouse-datasource",
    "pluginName": "ClickHouse",
    "docURL": "https://grafana.com/grafana/plugins/grafana-clickhouse-datasource/",
    "fields": [
        {
            "id": "jsonData_host",
            "key": "host",
            "label": "Server address",
            "description": "ClickHouse host address",
            "valueType": "string",
            "target": "jsonData",
            "role": "endpoint.domain",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "Server address"
            }
        },
        {
            "id": "jsonData_port",
            "key": "port",
            "label": "Server port",
            "description": "ClickHouse server port",
            "valueType": "number",
            "target": "jsonData",
            "role": "endpoint.port",
            "required": true,
            "defaultValue": 9000,
            "help": {
                "markdown": "ClickHouse supports two server protocols: Native TCP and HTTP. Both protocols can be secured with TLS. <br/>[Native TCP](https://clickhouse.com/docs/interfaces/tcp) is the default and recommended option.<br/>[HTTP](https://clickhouse.com/docs/interfaces/http) is for servers configured to accept HTTP connections."
            },
            "ui": {
                "component": "input"
            },
            "overrides": [
                {
                    "when": "jsonData_protocol == 'http'",
                    "defaultValue": 8123,
                    "tooltip": "ClickHouse server port (default for HTTP: 8123)"
                }
            ]
        },
        {
            "id": "jsonData_protocol",
            "key": "protocol",
            "label": "Protocol",
            "description": "Native or HTTP for server protocol",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "native",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "native",
                        "http"
                    ]
                }
            ],
            "ui": {
                "component": "radio",
                "options": [
                    {
                        "label": "Native",
                        "value": "native"
                    },
                    {
                        "label": "HTTP",
                        "value": "http"
                    }
                ]
            }
        },
        {
            "id": "jsonData_secure",
            "key": "secure",
            "label": "Secure Connection",
            "description": "Toggle on if the connection is secure",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_path",
            "key": "path",
            "label": "HTTP URL Path",
            "description": "Additional URL path for HTTP requests",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData_protocol == 'http'",
            "ui": {
                "component": "input",
                "placeholder": "additional-path"
            }
        },
        {
            "id": "jsonData_username",
            "key": "username",
            "label": "Username",
            "description": "ClickHouse username",
            "valueType": "string",
            "target": "jsonData",
            "role": "auth.basic.username",
            "ui": {
                "component": "input",
                "placeholder": "default"
            }
        },
        {
            "id": "secureJsonData_password",
            "key": "password",
            "label": "Password",
            "description": "ClickHouse password",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "auth.basic.password",
            "ui": {
                "component": "input",
                "placeholder": "password"
            }
        },
        {
            "id": "jsonData_tlsSkipVerify",
            "key": "tlsSkipVerify",
            "label": "Skip TLS Verify",
            "description": "Skip TLS Verify",
            "valueType": "boolean",
            "target": "jsonData",
            "role": "transport.tlsSkipVerify",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_tlsAuth",
            "key": "tlsAuth",
            "label": "TLS Client Auth",
            "description": "TLS Client Auth",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_tlsAuthWithCACert",
            "key": "tlsAuthWithCACert",
            "label": "With CA Cert",
            "description": "Needed for verifying self-signed TLS Certs",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "secureJsonData_tlsCACert",
            "key": "tlsCACert",
            "label": "CA Cert",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "tls.caCert",
            "dependsOn": "jsonData_tlsAuthWithCACert == true",
            "ui": {
                "component": "textarea",
                "multiline": true,
                "rows": 7,
                "placeholder": "CA Cert. Begins with -----BEGIN CERTIFICATE-----"
            }
        },
        {
            "id": "secureJsonData_tlsClientCert",
            "key": "tlsClientCert",
            "label": "Client Cert",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "tls.clientCert",
            "dependsOn": "jsonData_tlsAuth == true",
            "ui": {
                "component": "textarea",
                "multiline": true,
                "rows": 7,
                "placeholder": "Client Cert. Begins with -----BEGIN CERTIFICATE-----"
            }
        },
        {
            "id": "secureJsonData_tlsClientKey",
            "key": "tlsClientKey",
            "label": "Client Key",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "tls.clientKey",
            "dependsOn": "jsonData_tlsAuth == true",
            "ui": {
                "component": "textarea",
                "multiline": true,
                "rows": 7,
                "placeholder": "Client Key. Begins with -----BEGIN RSA PRIVATE KEY-----"
            }
        },
        {
            "id": "jsonData_configMode",
            "key": "configMode",
            "label": "Mode",
            "description": "Choose how this datasource is used. 'Single table' provides a focused, compact query editor for one table. 'All databases' gives full access to explore any database and table.",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "classic",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "classic",
                        "single-table"
                    ]
                }
            ],
            "ui": {
                "component": "radio",
                "options": [
                    {
                        "label": "All databases",
                        "value": "classic"
                    },
                    {
                        "label": "Single table",
                        "value": "single-table"
                    }
                ]
            }
        },
        {
            "id": "jsonData_signalType",
            "key": "signalType",
            "label": "Signal type",
            "description": "What kind of data does this table contain?",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData_configMode == 'single-table'",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "logs",
                        "traces"
                    ]
                }
            ],
            "ui": {
                "component": "radio",
                "options": [
                    {
                        "label": "Logs",
                        "value": "logs",
                        "description": "Log search with severity, message, and attributes"
                    },
                    {
                        "label": "Traces",
                        "value": "traces",
                        "description": "Distributed tracing with spans and service maps"
                    }
                ]
            }
        },
        {
            "id": "jsonData_defaultDatabase",
            "key": "defaultDatabase",
            "label": "Default database",
            "description": "the default database used by the query builder",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "default"
            }
        },
        {
            "id": "jsonData_defaultTable",
            "key": "defaultTable",
            "label": "Default table",
            "description": "the default table used by the query builder",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "table"
            }
        },
        {
            "id": "jsonData_dialTimeout",
            "key": "dialTimeout",
            "label": "Dial Timeout (seconds)",
            "description": "Timeout in seconds for connection",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "10",
            "ui": {
                "component": "input",
                "placeholder": "10"
            }
        },
        {
            "id": "jsonData_queryTimeout",
            "key": "queryTimeout",
            "label": "Query Timeout (seconds)",
            "description": "Timeout in seconds for read queries",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "60",
            "ui": {
                "component": "input",
                "placeholder": "60"
            }
        },
        {
            "id": "jsonData_connMaxLifetime",
            "key": "connMaxLifetime",
            "label": "Connection Max Lifetime (minutes)",
            "description": "Maximum lifetime of a connection in minutes",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "5",
            "ui": {
                "component": "input",
                "placeholder": "5"
            }
        },
        {
            "id": "jsonData_maxIdleConns",
            "key": "maxIdleConns",
            "label": "Max Idle Connections",
            "description": "Maximum number of idle connections",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "25",
            "ui": {
                "component": "input",
                "placeholder": "25"
            }
        },
        {
            "id": "jsonData_maxOpenConns",
            "key": "maxOpenConns",
            "label": "Max Open Connections",
            "description": "Maximum number of open connections",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "50",
            "ui": {
                "component": "input",
                "placeholder": "50"
            }
        },
        {
            "id": "jsonData_validateSql",
            "key": "validateSql",
            "label": "Validate SQL",
            "description": "Validate SQL in the editor.",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_enableMapKeysDiscovery",
            "key": "enableMapKeysDiscovery",
            "label": "Suggest Map keys in filter editor",
            "description": "When enabled, the filter editor probes Map(...) columns for distinct keys to populate the key-suggestion dropdown. On large tables with high-cardinality maps this probe can scan billions of rows. Disable to suppress the probe — operators can still type Map keys manually. Defaults to enabled.",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": true,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_logs_defaultDatabase",
            "key": "defaultDatabase",
            "section": "logs",
            "label": "Default log database",
            "description": "the default database used by the logs query builder",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "default"
            }
        },
        {
            "id": "jsonData_logs_defaultTable",
            "key": "defaultTable",
            "section": "logs",
            "label": "Default log table",
            "description": "the default table used by the logs query builder",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "otel_logs",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_logs_otelEnabled",
            "key": "otelEnabled",
            "section": "logs",
            "label": "Use OTel",
            "description": "Enables Open Telemetry schema versioning",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_logs_otelVersion",
            "key": "otelVersion",
            "section": "logs",
            "label": "OTel version",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "latest",
            "ui": {
                "component": "select",
                "allowCustom": false
            }
        },
        {
            "id": "jsonData_logs_filterTimeColumn",
            "key": "filterTimeColumn",
            "section": "logs",
            "label": "Filter Time column",
            "description": "A lower precision column for filtering logs by timestamp",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_logs_timeColumn",
            "key": "timeColumn",
            "section": "logs",
            "label": "Time column",
            "description": "Column for the log timestamp, used for high precision sorting",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_logs_levelColumn",
            "key": "levelColumn",
            "section": "logs",
            "label": "Log Level column",
            "description": "Column for the log level",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_logs_messageColumn",
            "key": "messageColumn",
            "section": "logs",
            "label": "Log Message column",
            "description": "Column for log message",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_logs_selectContextColumns",
            "key": "selectContextColumns",
            "section": "logs",
            "label": "Auto-Select Columns",
            "description": "When enabled, will always include context columns in log queries",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": true,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_logs_contextColumns",
            "key": "contextColumns",
            "section": "logs",
            "label": "Context Columns",
            "description": "Comma separated list of column names to use for identifying a log's source",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "string"
            },
            "ui": {
                "component": "list",
                "placeholder": "Column name (enter key to add)"
            }
        },
        {
            "id": "jsonData_logs_showLogLinks",
            "key": "showLogLinks",
            "section": "logs",
            "label": "Show \"View logs\" links",
            "description": "Show \"View logs\" links on trace_id/traceid fields.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_traces_defaultDatabase",
            "key": "defaultDatabase",
            "section": "traces",
            "label": "Default trace database",
            "description": "the default database used by the trace query builder",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "default"
            }
        },
        {
            "id": "jsonData_traces_defaultTable",
            "key": "defaultTable",
            "section": "traces",
            "label": "Default trace table",
            "description": "the default table used by the trace query builder",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "otel_traces",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_otelEnabled",
            "key": "otelEnabled",
            "section": "traces",
            "label": "Use OTel",
            "description": "Enables Open Telemetry schema versioning",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_traces_otelVersion",
            "key": "otelVersion",
            "section": "traces",
            "label": "OTel version",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "latest",
            "ui": {
                "component": "select",
                "allowCustom": false
            }
        },
        {
            "id": "jsonData_traces_traceIdColumn",
            "key": "traceIdColumn",
            "section": "traces",
            "label": "Trace ID column",
            "description": "Column for the trace ID",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_spanIdColumn",
            "key": "spanIdColumn",
            "section": "traces",
            "label": "Span ID column",
            "description": "Column for the span ID",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_operationNameColumn",
            "key": "operationNameColumn",
            "section": "traces",
            "label": "Operation Name column",
            "description": "Column for the operation name",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_parentSpanIdColumn",
            "key": "parentSpanIdColumn",
            "section": "traces",
            "label": "Parent Span ID column",
            "description": "Column for the parent span ID",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_serviceNameColumn",
            "key": "serviceNameColumn",
            "section": "traces",
            "label": "Service Name column",
            "description": "Column for the service name",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_durationColumn",
            "key": "durationColumn",
            "section": "traces",
            "label": "Duration Time column",
            "description": "Column for the duration time",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_durationUnit",
            "key": "durationUnit",
            "section": "traces",
            "label": "Duration Unit",
            "description": "Unit used by your Duration column. OTel stores nanoseconds; other schemas often use milliseconds or seconds.",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "nanoseconds",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "nanoseconds",
                        "microseconds",
                        "milliseconds",
                        "seconds"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "Nanoseconds",
                        "value": "nanoseconds"
                    },
                    {
                        "label": "Microseconds",
                        "value": "microseconds"
                    },
                    {
                        "label": "Milliseconds",
                        "value": "milliseconds"
                    },
                    {
                        "label": "Seconds",
                        "value": "seconds"
                    }
                ]
            }
        },
        {
            "id": "jsonData_traces_startTimeColumn",
            "key": "startTimeColumn",
            "section": "traces",
            "label": "Start Time column",
            "description": "Column for the start time",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_tagsColumn",
            "key": "tagsColumn",
            "section": "traces",
            "label": "Tags column",
            "description": "Column for the trace tags",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_serviceTagsColumn",
            "key": "serviceTagsColumn",
            "section": "traces",
            "label": "Service Tags column",
            "description": "Column for the service tags",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_kindColumn",
            "key": "kindColumn",
            "section": "traces",
            "label": "Kind column",
            "description": "Column for the trace kind",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_statusCodeColumn",
            "key": "statusCodeColumn",
            "section": "traces",
            "label": "Status Code column",
            "description": "Column for the trace status code",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_statusMessageColumn",
            "key": "statusMessageColumn",
            "section": "traces",
            "label": "Status Message column",
            "description": "Column for the trace status message",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_stateColumn",
            "key": "stateColumn",
            "section": "traces",
            "label": "State column",
            "description": "Column for the trace state",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_instrumentationLibraryNameColumn",
            "key": "instrumentationLibraryNameColumn",
            "section": "traces",
            "label": "Library Name column",
            "description": "Column for the instrumentation library name",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_instrumentationLibraryVersionColumn",
            "key": "instrumentationLibraryVersionColumn",
            "section": "traces",
            "label": "Library Version column",
            "description": "Column for the instrumentation library version",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_flattenNested",
            "key": "flattenNested",
            "section": "traces",
            "label": "Use Flatten Nested",
            "description": "Enable if your traces table was created with flatten_nested=1",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_traces_traceEventsColumnPrefix",
            "key": "traceEventsColumnPrefix",
            "section": "traces",
            "label": "Events prefix",
            "description": "Prefix for the events column (Events.Timestamp, Events.Name, etc.)",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_traceLinksColumnPrefix",
            "key": "traceLinksColumnPrefix",
            "section": "traces",
            "label": "Links prefix",
            "description": "Prefix for the trace references column (Links.TraceId, Links.TraceState, etc.)",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData_traces_showTraceLinks",
            "key": "showTraceLinks",
            "section": "traces",
            "label": "Show \"View trace\" links",
            "description": "Show \"View trace\" links on trace_id/traceid fields.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_traces_traceTimestampTableSuffix",
            "key": "traceTimestampTableSuffix",
            "section": "traces",
            "label": "Trace timestamp table suffix",
            "description": "Suffix appended to the traces table name to locate a companion index keyed by TraceId with Start/End columns. When such a table exists, trace ID lookups narrow the main query to a small time window instead of scanning the whole table. Leave blank to use the OTel default (_trace_id_ts).",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "_trace_id_ts"
            }
        },
        {
            "id": "jsonData_httpHeaders",
            "key": "httpHeaders",
            "label": "Custom HTTP Headers",
            "description": "Add Custom HTTP headers when querying the database",
            "valueType": "array",
            "target": "jsonData",
            "dependsOn": "jsonData_protocol == 'http'",
            "item": {
                "valueType": "object",
                "fields": [
                    {
