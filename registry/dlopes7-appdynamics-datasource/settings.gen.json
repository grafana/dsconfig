{
  "spec": {
    "type": "object",
    "required": [
      "url"
    ],
    "properties": {
      "basicAuth": {
        "type": "boolean",
        "default": false
      },
      "basicAuthUser": {
        "type": "string",
        "x-dsconfig-depends-on": "root_basicAuth == true",
        "x-dsconfig-required-when": "root_basicAuth == true"
      },
      "jsonData": {
        "type": "object",
        "properties": {
          "analyticsURL": {
            "description": "The Analytics API URL",
            "type": "string"
          },
          "clientDomain": {
            "type": "string",
            "x-dsconfig-required-when": "jsonData_clientName != '' || secureJsonData_clientSecret != ''"
          },
          "clientName": {
            "type": "string",
            "x-dsconfig-required-when": "jsonData_clientDomain != '' || secureJsonData_clientSecret != ''"
          },
          "globalAccountName": {
            "description": "The global account name, as shown in the Controller UI License page.",
            "type": "string"
          },
          "httpHeaders": {
            "description": "Additional HTTP headers sent with every request. Header names are stored in jsonData (httpHeaderName\u003cN\u003e); header values are write-only in secureJsonData (httpHeaderValue\u003cN\u003e).",
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[A-Za-z][A-Za-z0-9-]*$"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "tlsSkipVerify": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "url": {
        "type": "string"
      }
    }
  },
  "secureValues": [
    {
      "key": "basicAuthPassword"
    },
    {
      "key": "clientSecret",
      "description": "Authenticate to AppDynamics using an API key. This will override username/password (basic) authenticationLeave blank for username/password authentication."
    },
    {
      "key": "analyticsAPIKey",
      "description": "The Analytics API Key"
    }
  ]
}
