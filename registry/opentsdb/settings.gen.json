{
  "spec": {
    "type": "object",
    "required": [
      "url"
    ],
    "properties": {
      "basicAuth": {
        "type": "boolean",
        "default": false
      },
      "basicAuthUser": {
        "type": "string",
        "x-dsconfig-depends-on": "root_basicAuth == true",
        "x-dsconfig-required-when": "root_basicAuth == true"
      },
      "jsonData": {
        "type": "object",
        "properties": {
          "httpHeaders": {
            "description": "Additional HTTP headers sent with every request. Header names are stored in jsonData (httpHeaderName\u003cN\u003e); header values are write-only in secureJsonData (httpHeaderValue\u003cN\u003e).",
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[A-Za-z][A-Za-z0-9-]*$"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "keepCookies": {
            "description": "Grafana proxy deletes forwarded cookies by default. Specify cookies by name that should be forwarded to the data source.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "lookupLimit": {
            "type": "number",
            "default": 1000,
            "minimum": 0
          },
          "oauthPassThru": {
            "description": "Forward the user's upstream OAuth identity to the data source (Their access token gets passed along).",
            "type": "boolean",
            "default": false
          },
          "serverName": {
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_tlsAuth == true",
            "x-dsconfig-required-when": "jsonData_tlsAuth == true"
          },
          "timeout": {
            "description": "HTTP request timeout in seconds",
            "type": "number"
          },
          "tlsAuth": {
            "type": "boolean",
            "default": false
          },
          "tlsAuthWithCACert": {
            "description": "Needed for verifying self-signed TLS Certs",
            "type": "boolean",
            "default": false
          },
          "tlsSkipVerify": {
            "type": "boolean",
            "default": false
          },
          "tsdbResolution": {
            "type": "number",
            "default": 1,
            "enum": [
              1,
              2
            ]
          },
          "tsdbVersion": {
            "type": "number",
            "default": 1,
            "enum": [
              1,
              2,
              3,
              4
            ]
          }
        }
      },
      "url": {
        "description": "Specify a complete HTTP URL (for example http://your_server:8080)",
        "type": "string"
      },
      "withCredentials": {
        "description": "Whether credentials such as cookies or auth headers should be sent with cross-site requests.",
        "type": "boolean",
        "default": false
      }
    }
  },
  "secureValues": [
    {
      "key": "basicAuthPassword"
    },
    {
      "key": "tlsCACert"
    },
    {
      "key": "tlsClientCert"
    },
    {
      "key": "tlsClientKey"
    }
  ]
}
