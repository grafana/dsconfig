{
  "spec": {
    "type": "object",
    "properties": {
      "jsonData": {
        "type": "object",
        "properties": {
          "services": {
            "type": "object",
            "properties": {
              "logicmonitor": {
                "type": "object",
                "properties": {
                  "auth": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Bearer token for LogicMonitor REST API v3.",
                        "type": "string",
                        "default": "auth_bearer",
                        "enum": [
                          "auth_bearer"
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "variables": {
            "type": "object",
            "required": [
              "account_name"
            ],
            "properties": {
              "account_name": {
                "description": "Your LogicMonitor account name. Example: Use foo for the logic monitor URL https://foo.logicmonitor.com/`",
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "secureValues": [
    {
      "key": "logicmonitor.token",
      "description": "Token for accessing the datasource API"
    }
  ]
}
