{
  "spec": {
    "type": "object",
    "properties": {
      "jsonData": {
        "type": "object",
        "required": [
          "assumeRoleArn",
          "workspaceId"
        ],
        "properties": {
          "assumeRoleArn": {
            "description": "Optional. Specifying the ARN of a role will ensure that the\n                     selected authentication provider is used to assume the role rather than the\n                     credentials directly.",
            "type": "string",
            "pattern": "^(arn:aws[a-zA-Z-]*:iam::[0-9]{12}:role/.+)?$"
          },
          "assumeRoleArnWriter": {
            "description": "Specify the ARN of a role to assume when writing property values in IoT TwinMaker",
            "type": "string",
            "pattern": "^(arn:aws[a-zA-Z-]*:iam::[0-9]{12}:role/.+)?$",
            "x-dsconfig-depends-on": "virtual_alarmConfigEnabled == true"
          },
          "authType": {
            "description": "Specify which AWS credentials chain to use.",
            "type": "string",
            "default": "default",
            "enum": [
              "default",
              "keys",
              "credentials",
              "ec2_iam_role",
              "grafana_assume_role",
              "arn"
            ]
          },
          "defaultRegion": {
            "description": "Specify the region, such as for US West (Oregon) use ` us-west-2 ` as the region.",
            "type": "string",
            "default": "us-east-1",
            "enum": [
              "ap-south-1",
              "ap-northeast-1",
              "ap-northeast-2",
              "ap-southeast-1",
              "ap-southeast-2",
              "eu-central-1",
              "eu-west-1",
              "us-east-1",
              "us-west-2",
              "us-gov-west-1",
              "cn-north-1"
            ]
          },
          "endpoint": {
            "description": "Optionally, specify a custom endpoint for the service",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_authType != 'grafana_assume_role'"
          },
          "externalId": {
            "description": "If you are assuming a role in another account, that has been created with an external ID, specify the external ID here.",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_authType != 'grafana_assume_role'"
          },
          "profile": {
            "description": "Credentials profile name, as specified in ~/.aws/credentials, leave blank for default.",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_authType == 'credentials'"
          },
          "workspaceId": {
            "type": "string"
          }
        }
      }
    }
  },
  "secureValues": [
    {
      "key": "accessKey"
    },
    {
      "key": "secretKey"
    }
  ]
}
