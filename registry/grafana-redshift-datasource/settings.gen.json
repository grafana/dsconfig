{
  "spec": {
    "type": "object",
    "properties": {
      "jsonData": {
        "type": "object",
        "properties": {
          "assumeRoleArn": {
            "description": "Optional. Specifying the ARN of a role will ensure that the selected authentication provider is used to assume the role rather than the credentials directly.",
            "type": "string",
            "pattern": "^(arn:aws[a-zA-Z-]*:iam::[0-9]{12}:role/.+)?$",
            "x-dsconfig-depends-on": "jsonData_authType != 'grafana_assume_role'"
          },
          "authType": {
            "description": "Specify which AWS credentials chain to use.",
            "type": "string",
            "default": "default",
            "enum": [
              "default",
              "keys",
              "credentials",
              "ec2_iam_role",
              "grafana_assume_role",
              "arn"
            ]
          },
          "clusterIdentifier": {
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_useServerless != true",
            "x-dsconfig-required-when": "jsonData_useServerless != true"
          },
          "database": {
            "type": "string",
            "x-dsconfig-required-when": "true"
          },
          "dbUser": {
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_useServerless != true || jsonData_useManagedSecret == true",
            "x-dsconfig-required-when": "jsonData_useServerless != true \u0026\u0026 jsonData_useManagedSecret != true"
          },
          "defaultRegion": {
            "description": "Specify the region, such as for US West (Oregon) use ` us-west-2 ` as the region.",
            "type": "string"
          },
          "endpoint": {
            "description": "Optionally, specify a custom endpoint for the service",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_authType != 'grafana_assume_role'"
          },
          "externalId": {
            "description": "If you are assuming a role in another account, that has been created with an external ID, specify the external ID here.",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_authType != 'grafana_assume_role'"
          },
          "managedSecret": {
            "type": "object",
            "properties": {
              "arn": {
                "type": "string",
                "x-dsconfig-depends-on": "jsonData_useManagedSecret == true",
                "x-dsconfig-required-when": "jsonData_useManagedSecret == true"
              },
              "name": {
                "type": "string",
                "x-dsconfig-depends-on": "jsonData_useManagedSecret == true"
              }
            }
          },
          "profile": {
            "description": "Credentials profile name, as specified in ~/.aws/credentials, leave blank for default.",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_authType == 'credentials'"
          },
          "useManagedSecret": {
            "type": "boolean",
            "default": false,
            "enum": [
              false,
              true
            ]
          },
          "useServerless": {
            "type": "boolean",
            "default": false
          },
          "withEvent": {
            "type": "boolean",
            "default": false
          },
          "workgroupName": {
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_useServerless == true",
            "x-dsconfig-required-when": "jsonData_useServerless == true"
          }
        }
      }
    }
  },
  "secureValues": [
    {
      "key": "accessKey"
    },
    {
      "key": "secretKey"
    },
    {
      "key": "sessionToken"
    }
  ]
}
