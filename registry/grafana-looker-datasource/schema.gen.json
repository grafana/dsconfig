{
  "targetApiVersion": "v0alpha1",
  "settings": {
    "spec": {
      "type": "object",
      "properties": {
        "jsonData": {
          "type": "object",
          "required": [
            "base_url"
          ],
          "properties": {
            "auth_type": {
              "description": "Looker authentication type",
              "type": "string",
              "default": "client_secret",
              "enum": [
                "client_secret"
              ]
            },
            "base_url": {
              "description": "Looker base URL. Example: https://00001234-1234-1ab2-1234-a1b2c3d4.looker.app",
              "type": "string"
            },
            "client_id": {
              "description": "API credentials Looker client id",
              "type": "string",
              "x-dsconfig-depends-on": "jsonData_authType == 'client_secret' || jsonData_authType == ''",
              "x-dsconfig-required-when": "jsonData_authType == 'client_secret'"
            }
          }
        }
      }
    },
    "secureValues": [
      {
        "key": "client_secret",
        "description": "API credentials Looker client secret"
      }
    ]
  },
  "settingsExamples": {
    "examples": {
      "": {
        "summary": "Default configuration",
        "description": "The defaults a new datasource starts with: client_secret authentication with an empty base URL, client ID, and client secret. jsonData.base_url, jsonData.client_id, and secureJsonData.client_secret must all be filled in to get a working datasource.",
        "value": {
          "jsonData": {
            "auth_type": "client_secret",
            "base_url": "",
            "client_id": ""
          },
          "secureJsonData": {
            "client_secret": ""
          }
        }
      },
      "clientSecret": {
        "summary": "Client Secret (Looker API3 credentials)",
        "description": "Authenticate against a Looker instance with API3 credentials: jsonData.client_id plus secureJsonData.client_secret, connecting to jsonData.base_url. auth_type is 'client_secret' (the only supported method).",
        "value": {
          "jsonData": {
            "auth_type": "client_secret",
            "base_url": "https://your-instance.looker.app",
            "client_id": "\u003cyour-client-id\u003e"
          },
          "secureJsonData": {
            "client_secret": "\u003cyour-client-secret\u003e"
          }
        }
      }
    }
  }
}
