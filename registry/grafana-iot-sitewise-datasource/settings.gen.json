{
  "spec": {
    "type": "object",
    "properties": {
      "jsonData": {
        "type": "object",
        "properties": {
          "assumeRoleArn": {
            "description": "Optional. Specifying the ARN of a role will ensure that the selected authentication provider is used to assume the role rather than the credentials directly.",
            "type": "string",
            "pattern": "^(arn:aws[a-zA-Z-]*:iam::[0-9]{12}:role/.+)?$",
            "x-dsconfig-depends-on": "(jsonData_defaultRegion != 'Edge' || jsonData_edgeAuthMode == 'default') \u0026\u0026 jsonData_authType != 'grafana_assume_role'"
          },
          "authType": {
            "description": "Specify which AWS credentials chain to use.",
            "type": "string",
            "default": "default",
            "enum": [
              "default",
              "keys",
              "credentials",
              "ec2_iam_role",
              "grafana_assume_role",
              "arn"
            ],
            "x-dsconfig-depends-on": "jsonData_defaultRegion != 'Edge' || jsonData_edgeAuthMode == 'default'"
          },
          "defaultRegion": {
            "description": "Specify the region, such as for US West (Oregon) use `us-west-2` as the region.",
            "type": "string",
            "enum": [
              "us-east-2",
              "us-east-1",
              "us-west-2",
              "ap-south-1",
              "ap-northeast-2",
              "ap-southeast-1",
              "ap-southeast-2",
              "ap-northeast-1",
              "ca-central-1",
              "eu-central-1",
              "eu-west-1",
              "us-gov-west-1",
              "cn-north-1",
              "Edge"
            ]
          },
          "edgeAuthMode": {
            "type": "string",
            "default": "default",
            "enum": [
              "default",
              "linux",
              "ldap"
            ],
            "x-dsconfig-depends-on": "jsonData_defaultRegion == 'Edge'"
          },
          "edgeAuthUser": {
            "description": "The username set to local authentication proxy",
            "type": "string",
            "x-dsconfig-depends-on": "jsonData_defaultRegion == 'Edge' \u0026\u0026 jsonData_edgeAuthMode != 'default'",
            "x-dsconfig-required-when": "jsonData_defaultRegion == 'Edge' \u0026\u0026 jsonData_edgeAuthMode != 'default'"
          },
          "endpoint": {
            "description": "Optionally, specify a custom endpoint for the service",
            "type": "string",
            "x-dsconfig-depends-on": "(jsonData_defaultRegion == 'Edge' \u0026\u0026 jsonData_edgeAuthMode != 'default') || jsonData_authType != 'grafana_assume_role'",
            "x-dsconfig-required-when": "jsonData_defaultRegion == 'Edge'"
          },
          "externalId": {
            "description": "If you are assuming a role in another account, that has been created with an external ID, specify the external ID here.",
            "type": "string",
            "x-dsconfig-depends-on": "(jsonData_defaultRegion != 'Edge' || jsonData_edgeAuthMode == 'default') \u0026\u0026 jsonData_authType != 'grafana_assume_role'"
          },
          "profile": {
            "description": "Credentials profile name, as specified in ~/.aws/credentials, leave blank for default.",
            "type": "string",
            "x-dsconfig-depends-on": "(jsonData_defaultRegion != 'Edge' || jsonData_edgeAuthMode == 'default') \u0026\u0026 jsonData_authType == 'credentials'"
          }
        }
      }
    }
  },
  "secureValues": [
    {
      "key": "accessKey"
    },
    {
      "key": "secretKey"
    },
    {
      "key": "sessionToken"
    },
    {
      "key": "edgeAuthPass",
      "description": "The password sent to local authentication proxy"
    },
    {
      "key": "cert",
      "description": "Certificate for SSL enabled authentication."
    }
  ]
}
