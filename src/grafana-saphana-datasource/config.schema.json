        {
            "id": "jsonData.port",
            "key": "port",
            "valueType": "number",
            "target": "jsonData"
        },
        {
            "id": "jsonData.instance",
            "key": "instance",
            "valueType": "number",
            "target": "jsonData"
        },
        {
            "id": "jsonData.databaseName",
            "key": "databaseName",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.defaultSchema",
            "key": "defaultSchema",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.tlsSkipVerify",
            "key": "tlsSkipVerify",
            "valueType": "boolean",
            "target": "jsonData"
        },
        {
            "id": "jsonData.tlsAuth",
            "key": "tlsAuth",
