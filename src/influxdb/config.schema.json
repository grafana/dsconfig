{
    "schemaVersion": "v1",
    "pluginType": "influxdb",
    "pluginName": "InfluxDB",
    "docURL": "https://grafana.com/docs/grafana/latest/datasources/influxdb/configure/",
    "fields": [
        {
            "id": "root.url",
            "key": "url",
            "label": "URL",
            "description": "The HTTP protocol, IP address, and port of your InfluxDB API. The default API port is 8086. When you enter a URL, Grafana attempts to auto-detect your InfluxDB product.",
            "valueType": "string",
            "semanticType": "url",
            "target": "root",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "example: http://localhost:8086/"
            }
        },
        {
            "id": "jsonData.product",
            "key": "product",
            "label": "Product",
            "description": "Select the InfluxDB product you're connecting to. The available query languages depend on your product selection. Use InfluxDB detection to identify the product from the URL.",
            "valueType": "string",
            "target": "jsonData",
            "required": true,
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "InfluxDB Cloud Dedicated",
                        "InfluxDB Cloud Serverless",
                        "InfluxDB Clustered",
                        "InfluxDB Enterprise 1.x",
                        "InfluxDB Enterprise 3.x",
                        "InfluxDB Cloud (TSM)",
                        "InfluxDB Cloud 1",
                        "InfluxDB OSS 1.x",
                        "InfluxDB OSS 2.x",
                        "InfluxDB OSS 3.x"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "InfluxDB Cloud Dedicated",
                        "value": "InfluxDB Cloud Dedicated"
                    },
                    {
                        "label": "InfluxDB Cloud Serverless",
                        "value": "InfluxDB Cloud Serverless"
                    },
                    {
                        "label": "InfluxDB Clustered",
                        "value": "InfluxDB Clustered"
                    },
                    {
                        "label": "InfluxDB Enterprise 1.x",
                        "value": "InfluxDB Enterprise 1.x"
                    },
                    {
                        "label": "InfluxDB Enterprise 3.x",
                        "value": "InfluxDB Enterprise 3.x"
                    },
                    {
                        "label": "InfluxDB Cloud (TSM)",
                        "value": "InfluxDB Cloud (TSM)"
                    },
                    {
                        "label": "InfluxDB Cloud 1",
                        "value": "InfluxDB Cloud 1"
                    },
                    {
                        "label": "InfluxDB OSS 1.x",
                        "value": "InfluxDB OSS 1.x"
                    },
                    {
                        "label": "InfluxDB OSS 2.x",
                        "value": "InfluxDB OSS 2.x"
                    },
                    {
                        "label": "InfluxDB OSS 3.x",
                        "value": "InfluxDB OSS 3.x"
                    }
                ]
            }
        },
        {
            "id": "jsonData.version",
            "key": "version",
            "label": "Query language",
            "description": "The query language depends on product selection.",
            "valueType": "string",
            "target": "jsonData",
            "required": true,
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "InfluxQL",
                        "Flux",
                        "SQL"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "SQL",
                        "value": "SQL"
                    },
                    {
                        "label": "InfluxQL",
                        "value": "InfluxQL"
                    },
                    {
                        "label": "Flux",
                        "value": "Flux"
                    }
                ]
            },
            "overrides": [
                {
                    "when": "jsonData.product == 'InfluxDB Cloud Dedicated' || jsonData.product == 'InfluxDB Clustered' || jsonData.product == 'InfluxDB Enterprise 3.x' || jsonData.product == 'InfluxDB OSS 3.x'",
                    "options": [
                        {
                            "label": "SQL",
                            "value": "SQL"
                        },
                        {
                            "label": "InfluxQL",
                            "value": "InfluxQL"
                        }
                    ],
                    "validations": [
                        {
                            "type": "allowedValues",
                            "values": [
                                "SQL",
                                "InfluxQL"
                            ]
                        }
                    ]
                },
                {
                    "when": "jsonData.product == 'InfluxDB Cloud Serverless'",
                    "options": [
                        {
                            "label": "SQL",
                            "value": "SQL"
                        },
                        {
                            "label": "InfluxQL",
                            "value": "InfluxQL"
                        },
                        {
                            "label": "Flux",
                            "value": "Flux"
                        }
                    ],
                    "validations": [
                        {
                            "type": "allowedValues",
                            "values": [
                                "SQL",
                                "InfluxQL",
                                "Flux"
                            ]
                        }
                    ]
                },
                {
                    "when": "jsonData.product == 'InfluxDB Cloud (TSM)' || jsonData.product == 'InfluxDB OSS 1.x' || jsonData.product == 'InfluxDB OSS 2.x' || jsonData.product == 'InfluxDB Enterprise 1.x'",
                    "options": [
                        {
                            "label": "InfluxQL",
                            "value": "InfluxQL"
                        },
                        {
                            "label": "Flux",
                            "value": "Flux"
                        }
                    ],
                    "validations": [
                        {
                            "type": "allowedValues",
                            "values": [
                                "InfluxQL",
                                "Flux"
                            ]
                        }
                    ]
                },
                {
                    "when": "jsonData.product == 'InfluxDB Cloud 1'",
                    "options": [
                        {
                            "label": "InfluxQL",
                            "value": "InfluxQL"
                        }
                    ],
                    "validations": [
                        {
                            "type": "allowedValues",
                            "values": [
                                "InfluxQL"
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "id": "jsonData.timeInterval",
            "key": "timeInterval",
            "label": "Min time interval",
            "description": "A lower limit for the auto group-by time interval. Recommended to be set to write frequency, for example 1m if your data is written every minute.",
            "valueType": "string",
            "semanticType": "duration",
            "target": "jsonData",
            "defaultValue": "10s",
            "ui": {
                "component": "input",
                "placeholder": "10s"
            }
        },
        {
            "id": "jsonData.httpMode",
            "key": "httpMode",
            "label": "HTTP Method",
            "description": "You can use either GET or POST HTTP method to query your InfluxDB database. The POST method allows you to perform heavy requests while the GET method will restrict you and return an error if the query is too large.",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.version == 'InfluxQL'",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "GET",
                        "POST"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "POST",
                        "value": "POST"
                    },
                    {
                        "label": "GET",
                        "value": "GET"
                    }
                ]
            }
        },
        {
            "id": "jsonData.dbName",
            "key": "dbName",
            "label": "Database",
            "description": "InfluxDB database name.",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.version == 'InfluxQL'"
        },
        {
            "id": "jsonData.oauthPassThru",
            "key": "oauthPassThru",
            "label": "Forward OAuth Identity",
            "description": "Forward the user's OAuth token to InfluxDB.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.organization",
            "key": "organization",
            "label": "Organization",
            "description": "InfluxDB organization ID.",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.version == 'Flux'"
        },
        {
            "id": "jsonData.defaultBucket",
            "key": "defaultBucket",
            "label": "Default Bucket",
            "description": "Default bucket for Flux queries.",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.version == 'Flux'",
            "ui": {
                "component": "input",
                "placeholder": "default bucket"
            }
        },
        {
            "id": "jsonData.maxSeries",
            "key": "maxSeries",
            "label": "Max series",
            "description": "Limit the number of series/tables that Grafana will process. Lower this to prevent abuse, increase if you have many small time series. Defaults to 1000.",
            "valueType": "number",
            "target": "jsonData",
            "defaultValue": 1000,
            "ui": {
                "component": "input",
                "placeholder": "1000"
            }
        },
        {
            "id": "jsonData.metadata",
            "key": "metadata",
            "label": "Metadata",
            "description": "SQL-mode metadata configuration.",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "map",
                "item": {
                    "valueType": "string"
                }
            },
            "dependsOn": "jsonData.version == 'SQL'"
        },
        {
            "id": "jsonData.insecureGrpc",
            "key": "insecureGrpc",
            "label": "Insecure gRPC connection",
            "description": "Use insecure (non-TLS) gRPC connection for SQL queries.",
            "valueType": "boolean",
            "target": "jsonData",
            "dependsOn": "jsonData.version == 'SQL'",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "secureJsonData.token",
            "key": "token",
            "label": "Token",
            "description": "Authentication token for Flux and SQL queries.",
            "valueType": "string",
            "semanticType": "token",
            "target": "secureJsonData"
        },
        {
            "id": "secureJsonData.password",
            "key": "password",
            "label": "Password",
            "description": "Password for InfluxQL basic auth.",
            "valueType": "string",
            "semanticType": "password",
            "target": "secureJsonData"
        }
    ],
    "groups": [
        {
            "id": "url-and-auth",
            "title": "URL and authentication",
            "fieldRefs": [
                "root.url",
                "jsonData.product",
                "jsonData.version"
            ]
        },
        {
            "id": "database-settings",
            "title": "Database settings",
            "fieldRefs": [
                "jsonData.dbName",
                "jsonData.organization",
                "jsonData.defaultBucket",
                "jsonData.httpMode",
                "jsonData.timeInterval",
                "jsonData.maxSeries",
                "jsonData.insecureGrpc",
                "jsonData.metadata"
            ]
        },
        {
            "id": "auth",
            "title": "Authentication",
            "fieldRefs": [
                "jsonData.oauthPassThru",
                "secureJsonData.token",
                "secureJsonData.password"
            ]
        }
    ]
}
