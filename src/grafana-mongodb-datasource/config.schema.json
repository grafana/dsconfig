        {
            "id": "jsonData.ccacheLookupFile",
            "key": "ccacheLookupFile",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.keyTabFilePath",
            "key": "keyTabFilePath",
            "valueType": "string",
            "target": "jsonData"
        },
