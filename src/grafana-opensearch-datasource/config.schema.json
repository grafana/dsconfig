            "target": "jsonData"
        },
        {
            "id": "jsonData.sigV4Auth",
            "key": "sigV4Auth",
            "valueType": "boolean",
            "target": "jsonData"
        },
        {
            "id": "jsonData.serverless",
            "key": "serverless",
            "valueType": "boolean",
            "target": "jsonData"
        },
