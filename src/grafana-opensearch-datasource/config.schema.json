            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "opensearch",
                        "elasticsearch"
                    ]
                }
            ]
        },
        {
            "id": "jsonData.interval",
            "key": "interval",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.timeInterval",
            "key": "timeInterval",
            "valueType": "string",
            "target": "jsonData",
            "required": true
